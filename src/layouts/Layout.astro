---
import '../styles/global.css'
import { getCollection } from 'astro:content'

export interface Props {
  title: string
  description?: string
  jsonld?: string
}

const { title, description, jsonld } = Astro.props

const settingsEntries = await getCollection('settings')
const settings = settingsEntries[0]?.data || {
  webhookUrl: '',
  whatsappNumber: '',
  enableAutoWebhook: false,
}
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | TiendaTop SSG</title>
    {description && <meta name="description" content={description} />}
    {jsonld && <script type="application/ld+json" set:html={jsonld}></script>}

  </head>
  <body
    class="min-h-screen bg-white text-gray-900 flex flex-col font-sans antialiased"
    data-webhook-url={settings.webhookUrl}
    data-whatsapp-number={settings.whatsappNumber}
    data-enable-auto-webhook={settings.enableAutoWebhook ? 'true' : 'false'}
  >
    <slot name="navbar" />
    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 pt-4 sm:pt-6">
      <slot />
    </main>
    <slot name="footer" />

    <!-- Search Overlay -->
    <div id="search-overlay" class="hidden fixed inset-0 z-50 bg-white/95 backdrop-blur-xl flex flex-col">
      <div class="p-4 sm:p-6 border-b border-gray-200 bg-gray-50 flex items-center gap-3">
        <div class="relative flex-1">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-amber-500 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input id="search-input" type="text" autofocus placeholder="Buscar productos con Fuse.js..." class="w-full bg-gray-100 border border-gray-300 rounded-2xl py-3 pl-11 pr-4 text-gray-900 placeholder:text-gray-400 text-sm outline-none focus:border-amber-500 transition">
        </div>
        <button id="search-close" class="min-h-[44px] px-4 rounded-xl bg-gray-200 hover:bg-gray-300 text-gray-700 font-bold text-xs active:scale-95 transition">Cancelar</button>
      </div>
      <div class="flex-1 overflow-y-auto p-4 sm:p-8 max-w-4xl mx-auto w-full">
        <div id="search-recent" class="mb-4"></div>
        <div id="search-results"></div>
      </div>
    </div>

    <!-- Cart Drawer Overlay -->
    <div id="cart-overlay" class="hidden fixed inset-0 z-40 bg-black/50 backdrop-blur-sm"></div>

    <!-- Cart Drawer (slide-in from right) -->
    <div id="cart-drawer" class="fixed top-0 right-0 z-50 h-full w-full max-w-md bg-white border-l border-gray-200 shadow-2xl translate-x-full transition-transform duration-300 ease-in-out flex flex-col">
      <div class="flex items-center justify-between p-4 border-b border-gray-200">
        <h2 class="text-lg font-black text-gray-900 flex items-center gap-2">
          <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>
          Carrito
        </h2>
        <button id="cart-close" class="p-2 text-gray-400 hover:text-gray-900 rounded-lg hover:bg-gray-100 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div id="cart-content" class="flex-1 overflow-y-auto p-4 space-y-4"></div>
    </div>

    <script>
      import { initCartDrawer } from '../lib/cart-drawer.js'
      initCartDrawer()
    </script>
  </body>
</html>
