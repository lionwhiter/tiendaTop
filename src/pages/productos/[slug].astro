---
import Layout from '../../layouts/Layout.astro'
import Navbar from '../../components/Navbar.astro'
import Footer from '../../components/Footer.astro'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const products = await getCollection('products')
  return products.map(p => ({
    params: { slug: p.slug },
    props: { product: p },
  }))
}

const { product } = Astro.props
const { data } = product

const jsonld = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: data.title,
  description: product.body?.trim() || data.title,
  image: data.image,
  sku: data.sku,
  category: data.category,
  offers: {
    '@type': 'Offer',
    price: data.price,
    priceCurrency: data.currency || 'USD',
    availability: data.stock > 0 ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
    priceValidUntil: new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
  },
})
---

<Layout title={data.title} description={data.title} jsonld={jsonld}>
  <fragment slot="navbar"><Navbar /></fragment>
  <fragment slot="footer"><Footer /></fragment>

  <nav class="text-xs text-gray-500 mb-4">
    <a href="/" class="hover:text-amber-500 transition">Inicio</a>
    <span class="mx-2">/</span>
    <a href="/" class="hover:text-amber-500 transition">{data.category}</a>
    <span class="mx-2">/</span>
    <span class="text-gray-600">{data.title}</span>
  </nav>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pb-12">
    <!-- Image -->
    <div class="relative aspect-square rounded-2xl overflow-hidden bg-white border border-gray-200">
      <img src={data.image} alt={data.title} class="w-full h-full object-cover" />
      {data.badge && (
        <div class="absolute top-4 left-4 z-10">
          <span class="px-3 py-1.5 rounded-lg text-xs font-black bg-amber-500 text-white">{data.badge}</span>
        </div>
      )}
    </div>

    <!-- Info -->
    <div class="flex flex-col gap-6">
      <div>
        <span class="text-xs font-bold uppercase tracking-wider text-amber-600">{data.category}</span>
        <h1 class="text-2xl sm:text-3xl font-black text-gray-900 mt-2">{data.title}</h1>
        <p class="text-xs text-gray-500 mt-1">SKU: {data.sku}</p>
      </div>

      <div class="flex items-baseline gap-3">
        <span class="text-3xl font-black text-amber-600">${data.price.toFixed(2)}</span>
        {data.originalPrice && (
          <span class="text-lg text-gray-400 line-through">${data.originalPrice.toFixed(2)}</span>
        )}
        <span class="text-sm font-bold" class:list={data.stock > 5 ? 'text-emerald-600' : 'text-red-500'}>
          ● Stock: {data.stock}
        </span>
      </div>

      <p class="text-gray-600 text-sm leading-relaxed">{product.body}</p>

      <button id="add-detail" class="w-full min-h-[52px] bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-400 hover:to-orange-400 text-white font-extrabold text-base rounded-xl shadow-xl shadow-orange-500/25 flex items-center justify-center gap-2 active:scale-95 transition" data-sku={product.slug} data-title={data.title} data-price={data.price} data-image={data.image} data-category={data.category}>
        Añadir al Carrito
      </button>

      <div class="bg-white border border-gray-200 rounded-2xl p-5 space-y-3 shadow-sm">
        <h3 class="font-bold text-gray-900 text-sm">Detalles del Producto</h3>
        <ul class="text-xs text-gray-500 space-y-2">
          <li><span class="text-gray-700 font-semibold">SKU:</span> {data.sku}</li>
          <li><span class="text-gray-700 font-semibold">Categoría:</span> {data.category}</li>
          <li><span class="text-gray-700 font-semibold">Stock:</span> {data.stock} unidades</li>
          <li><span class="text-gray-700 font-semibold">Moneda:</span> {data.currency || 'USD'}</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>

<script>
import { addToCart } from '../../lib/cart.js'

document.getElementById('add-detail')?.addEventListener('click', function () {
  addToCart({
    sku: this.dataset.sku,
    title: this.dataset.title,
    price: parseFloat(this.dataset.price),
    image: this.dataset.image,
    category: this.dataset.category,
  })
})
</script>
