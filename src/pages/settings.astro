---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const settingsEntries = await getCollection("settings");
const s = settingsEntries[0]?.data || {
  webhookUrl: "",
  whatsappNumber: "",
  enableAutoWebhook: false,
};
---

<Layout
  title="Contacto"
  description="Contactos e información de WhatsApp para tu tienda"
>
  <fragment slot="navbar"><Navbar /></fragment>
  <fragment slot="footer"><Footer /></fragment>

  <div class="max-w-4xl mx-auto py-8 px-4 sm:px-6 space-y-8">
    <div
      class="pb-4 border-b border-gray-200 flex items-center justify-between"
    >
      <div class="flex items-center gap-3">
        <div
          class="p-3 bg-gray-100 rounded-2xl border border-gray-200 text-gray-700"
        >
          <svg
            class="w-6 h-6 text-amber-500"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"
            ></path><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
          >
        </div>
        <div>
          <h1 class="text-2xl font-black text-gray-900 tracking-tight">
            Contactos
          </h1>
          <p class="text-xs text-gray-500">
            Te atenderemos y brindaremos el mejor asesoramiento
          </p>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
      <div
        class="md:col-span-7 bg-white border border-gray-200 rounded-3xl p-6 sm:p-8 shadow-lg space-y-6"
      >
        <div class="space-y-4">
          <!--div>
            <label class="block text-xs font-bold uppercase tracking-wider text-gray-600 mb-1.5 flex items-center gap-2">
              <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
              URL del Webhook
            </label>
            <p class="bg-gray-100 border border-gray-300 rounded-xl px-4 py-3 text-gray-900 text-xs sm:text-sm font-mono break-all" id="webhook-display">{s.webhookUrl}</p>
          </div-->

          <div>
            <label
              class="block text-xs font-bold uppercase tracking-wider text-gray-600 mb-1.5 flex items-center gap-2"
            >
              <svg
                class="w-4 h-4 text-emerald-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path></svg
              >
              Número de WhatsApp
            </label>
            <p
              class="bg-gray-100 border border-gray-300 rounded-xl px-4 py-3 text-gray-900 text-xs sm:text-sm font-mono"
              id="whatsapp-display"
            >
              {s.whatsappNumber}
            </p>
          </div>

          <!--div class="pt-2">
            <label class="flex items-center gap-3 bg-gray-100 p-4 rounded-xl border border-gray-200 cursor-not-allowed select-none">
              <input
                type="checkbox"
                disabled
                class="w-5 h-5 rounded border-gray-300 text-amber-500 cursor-not-allowed opacity-60"
                checked={s.enableAutoWebhook}
              />
              <span class="text-xs sm:text-sm font-semibold text-gray-500">
                Envío automático al webhook: <strong class={s.enableAutoWebhook ? 'text-green-600' : 'text-gray-400'}>{s.enableAutoWebhook ? 'Activado' : 'Desactivado'}</strong>
              </span>
            </label>
          </div-->
        </div>

        <!--a
          href="/admin/#/collections/settings"
          class="block w-full min-h-[48px] rounded-xl font-extrabold text-sm flex items-center justify-center gap-2 shadow-xl active:scale-95 transition bg-gradient-to-r from-amber-500 to-orange-500 hover:from-amber-400 hover:to-orange-400 text-white shadow-orange-500/20"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          <span>Editar en el CMS</span>
        </a-->
      </div>

      <!--div class="md:col-span-5 bg-gradient-to-br from-gray-50 to-indigo-50/40 border border-gray-200 rounded-3xl p-6 sm:p-8 space-y-4">
        <h3 class="text-base font-black text-amber-600 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span>¿Cómo funciona?</span>
        </h3>

        <ol class="space-y-3 text-xs text-gray-600 list-decimal pl-4 leading-relaxed marker:font-bold marker:text-amber-500">
          <li>Los valores se guardan en <strong class="text-gray-900">src/content/settings/config.yaml</strong>.</li>
          <li>Para modificarlos, usa el botón <strong class="text-gray-900">"Editar en el CMS"</strong> o edita el archivo YAML directamente.</li>
          <li>Los cambios se inyectan en el HTML al construir el sitio (<strong class="text-gray-900">build time</strong>).</li>
          <li>No se almacena nada en <strong class="text-gray-900">localStorage</strong> — mayor seguridad.</li>
        </ol>

        <div class="pt-4 border-t border-gray-200">
          <a href="https://www.make.com" target="_blank" rel="noreferrer" class="text-xs text-amber-600 font-bold hover:underline inline-flex items-center gap-1">
            <span>Ir a Make.com gratis</span>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      </div-->
      <div
        class="md:col-span-5 bg-gradient-to-br from-gray-50 to-indigo-50/40 border border-gray-200 rounded-3xl p-6 sm:p-8 space-y-4"
      >
        <h3 class="text-base font-black text-amber-600 flex items-center gap-2">
          <!-- Ícono de lista de verificación / proceso -->
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
            ></path></svg
          >
          <span>¿Cómo trabajamos?</span>
        </h3>

        <ol
          class="space-y-3 text-xs text-gray-600 list-decimal pl-4 leading-relaxed marker:font-bold marker:text-amber-500"
        >
          <li>
            Explora nuestro catálogo online. Todos los productos y precios se
            actualizan en tiempo real.
          </li>
          <li>
            Agrega tus productos al carrito y envíanos tu pedido directamente
            por <strong class="text-gray-900">WhatsApp con un clic</strong>.
          </li>
          <li>
            Recibimos tu orden al instante y <strong class="text-gray-900"
              >confirmamos la disponibilidad</strong
            > y los datos de envío contigo.
          </li>
          <li>
            Preparamos tu pedido y te lo enviamos. <strong class="text-gray-900"
              >Pagas y recibes </strong
              >en tu encomienda preferida.
          </li>
        </ol>

        <div class="pt-4 border-t border-gray-200"> 
          <a
            href="/"
            class="text-xs text-amber-600 font-bold hover:underline inline-flex items-center gap-1"
          >
            <span>Ir al catálogo</span>
            <!-- Ícono de flecha -->
            <svg
              class="w-3 h-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
            >
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
